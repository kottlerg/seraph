# /tests/inputtest — virtio-input keyboard driver smoke test.
#
# Driven by `cargo xtask test-input`, which boots with a QMP control socket,
# waits for this test's READY marker on the serial log, injects a known key
# sequence, and asserts the `ALL TESTS PASSED` marker. One-shot: exits on
# completion; svcmgr never restarts it.
#
# Seeds resolve through svcmgr's discovery registry: devmgr.registry is the
# REGISTRY_QUERY_AUTHORITY SEND used for QUERY_INPUT_DEVICE; pwrmgr.shutdown is
# the SHUTDOWN_AUTHORITY SEND used to power off on completion.
#
# Recipe lives under /config/svcmgr/tests/, which svcmgr does NOT scan. To
# enable in a boot, copy this file into /config/svcmgr/services/ and repack
# (`cargo xtask mkdisk`) between `cargo xtask build` and `cargo xtask
# test-input`. See docs/testing.md.
binary    = /tests/inputtest
restart   = never
critical  = no
namespace = none
seed      = devmgr.registry pwrmgr.shutdown
