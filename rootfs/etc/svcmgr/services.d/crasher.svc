# /bin/crasher — intentional fault-test fixture for the restart path.
#
# Touches no filesystem; only IPC dependency is the svcmgr service
# endpoint (svcmgr publishes itself at handover under the name
# `svcmgr`). Restart on every exit so a single boot exercises the
# restart-budget envelope; critical = low because crashes are the
# point.
binary    = /bin/crasher
restart   = always
critical  = low
namespace = none
seed      = svcmgr
